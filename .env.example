# 后端 API base
NUXT_PUBLIC_API_BASE=http://localhost:8080

# 图片/海报 OSS 前缀（与 admin .env 中的 NEXT_PUBLIC_IMAGE_URL 保持一致）
NUXT_PUBLIC_IMAGE_BASE=http://drive.bangumi.xyz:9000/test-movie

# App 商店链接（可选）
NUXT_PUBLIC_APP_STORE_URL=
NUXT_PUBLIC_GOOGLE_PLAY_URL=

# App scheme，用于分享页 deep link 唤起
NUXT_PUBLIC_APP_SCHEME=otakumovie

# 官网地址（用于 sitemap / OG URL / manifest）
NUXT_PUBLIC_SITE_URL=https://example.com

# 客服邮箱（可选；配置后 Footer 会展示"联系我们"）
NUXT_PUBLIC_SUPPORT_EMAIL=diy4869@gmail.com
